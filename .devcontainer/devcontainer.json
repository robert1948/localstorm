{
  "name": "LocalStorm Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [8000, 5173],
  "postCreateCommand": "npm install --prefix client && pip install -r backend/requirements.txt",
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "esbenp.prettier-vscode"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
        }
      }
    }
  }
