{
  "name": "LocalStorm Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [8000, 5173],
  "postCreateCommand": "cd /workspace/client && npm install && cd /workspace/backend && pip install -r requirements.txt",

  "features": {},
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "esbenp.prettier-vscode"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
        }
      }
    }
  }
